{
  "name": "@signal-forge/mcp",
  "version": "0.13.2",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#mcp/*": {
      "types": "./src/*.ts",
      "bun": "./src/*.ts",
      "default": "./dist/*.mjs"
    }
  },
  "main": "./dist/server.mjs",
  "exports": {
    ".": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs",
      "default": "./dist/server.mjs"
    },
    "./stdio": {
      "types": "./dist/stdio.d.mts",
      "import": "./dist/stdio.mjs",
      "default": "./dist/stdio.mjs"
    }
  },
  "bin": {
    "signalforge-mcp": "./dist/stdio.mjs",
    "signalforge-mcp-http": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx tsdown --config tsdown.config.ts",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-pencil/open-pencil.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@signal-forge/core": "workspace:*",
    "hono": "^4.12.5",
    "package-manager-detector": "^1.6.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1"
  }
}
